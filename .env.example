# =============================================================================
# client-voice-data Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit the actual .env file (it's in .gitignore).
# =============================================================================

# --- Snowflake (read-only analytics) ---
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=capim_data
SNOWFLAKE_ROLE=data_user

# --- PostgreSQL: vox_popular (CLIENT_VOICE data store) ---
VOX_POPULAR_HOST=
VOX_POPULAR_PORT=5432
VOX_POPULAR_DB=vox_popular
VOX_POPULAR_USER=
VOX_POPULAR_PASSWORD=

# --- LLM APIs (for classification pipeline) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
