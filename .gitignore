# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/

# Snowflake credentials
.env

# Data files (no CSV commits - default block all)
*.csv
*.xlsx
*.parquet

# Intermediate data — checkpoints, phase results, reprocessed outputs
# These are ephemeral artifacts from LLM processing runs.
# Golden sets and canonical vocabs are excluded (kept intentionally).
data/reprocessed/
data/phase1/
data/phase2/
data/validation/
data/calibration/
data/*.jsonl
data/crash_log.txt

# Archive folders (local-only, not tracked)
**/_archive/
scripts/archive/

# Temporary workspace (future-proof for scratchpad work)
_scratch/

# Generated outputs (transitório)
outputs/
queries/**/_results.csv

# Temporary EDA artifacts (when EDA is added in future)
eda/**/outputs/temp_*
eda/**/*_temp.csv
eda/**/*_debug.png

# BUT: Allow intentionally published artifacts (explicit opt-in)
# Uncomment when needed:
# !eda/**/plots/*.png
# !docs/**/*.png

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
